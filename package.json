{
  "name": "xiaolongxia-web",
  "version": "0.1.0",
  "description": "小龙虾 AI 团队桌面应用",
  "author": "OpenAI Codex",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "skills:sync": "node scripts/sync-skill-catalog.mjs",
    "skills:create": "node scripts/create-local-skill.mjs",
    "predev": "node scripts/sync-skill-catalog.mjs",
    "dev:ws": "node server/ws-server.js",
    "dev:next": "next dev -p 3000",
    "dev": "concurrently -n WS,Next -c cyan,yellow \"node server/ws-server.js\" \"next dev -p 3000\"",
    "preelectron:dev": "node scripts/sync-skill-catalog.mjs",
    "electron:dev": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ node scripts/electron-dev.js",
    "electron:dev:clean": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ node scripts/electron-dev.js --clean",
    "prototype:dispatch": "node prototypes/hermes-dispatch/run.mjs",
    "prebuild": "node scripts/sync-skill-catalog.mjs",
    "build": "next build",
    "typecheck": "node scripts/typecheck.mjs",
    "electron:build": "cross-env ELECTRON_BUILD=true ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ next build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win nsis portable",
    "electron:build:mac": "cross-env ELECTRON_BUILD=true ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ next build && cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --mac",
    "start": "next start"
  },
  "build": {
    "appId": "com.xiaolongxia.ai",
    "productName": "小龙虾AI团队",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**",
      "out/**",
      "prototypes/**",
      "server/**",
      "public/**",
      "node_modules/**",
      "!node_modules/.cache",
      "!node_modules/electron",
      "!node_modules/electron-builder"
    ],
    "asarUnpack": [
      "out/**"
    ],
    "extraResources": [
      {
        "from": "server/",
        "to": "server/"
      },
      {
        "from": "public/splash/",
        "to": "splash/"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@browserbasehq/stagehand": "^3.2.0",
    "docx": "^9.6.1",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "next": "14.2.5",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0",
    "pptxgenjs": "^4.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "ws": "^8.20.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "wait-on": "^8.0.0"
  }
}

ANTHROPIC_BASE_URL=https://gaccode.com/claudecode

# ── LLM API Key（选一个）──────────────────────────────
# 方式1: SiliconFlow（推荐，支持 DeepSeek/Qwen，更便宜）
# SILICONFLOW_API_KEY=sk-xxx

# 方式2: OpenAI 直连
# OPENAI_API_KEY=sk-xxx

# 方式3: 其他兼容 OpenAI 格式的接口
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.4sapi.com/v1

# 可选：固定使用某个模型（不填则按任务复杂度自动路由）
# OPENAI_MODEL=gpt-4o-mini


# ── 图片生成 API Key（选一个）────────────────────────
# 方式1: inference.sh（支持 Seedream 4.5 / Nano Banana）
# INFSH_API_KEY=infsh-xxx
# IMAGE_MODEL=seedream-4-5   # 可选: seedream-4-5 | nano-banana | seedream-3-0

# 方式2: SiliconFlow（复用上面的 key，自动使用 FLUX.1-schnell）
# 如果设置了 SILICONFLOW_API_KEY，图片生成会自动使用它，无需额外配置

# 不配置任何图片 key 时，幻影龙虾会使用占位图（picsum.photos）

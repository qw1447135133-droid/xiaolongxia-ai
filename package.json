{
  "name": "xiaolongxia-ai",
  "version": "0.1.0",
  "description": "小龙虾 AI 跨境电商多 Agent 团队",
  "private": true,
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "xiaolongxia": "dist/cli.js"
  },
  "scripts": {
    "dev": "node -e \"const {execSync}=require('child_process'); execSync('npm run dev', {cwd:'apps/web', stdio:'inherit'})\"",
    "install:web": "node -e \"const {execSync}=require('child_process'); execSync('npm install', {cwd:'apps/web', stdio:'inherit'})\"",
    "build": "tsc",
    "pkg": "node build.js",
    "gui": "node gui-server.js"
  },
  "pkg": {
    "assets": [
      ".env.example",
      "dist/**/*.js",
      "gui/**/*"
    ],
    "scripts": [
      "dist/**/*.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "release"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.116.0",
    "openai": "^4.52.0",
    "eventemitter3": "^5.0.0",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "open": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "pkg": "^5.8.1",
    "typescript": "^5.0.0",
    "tsx": "^4.0.0"
  }
}
